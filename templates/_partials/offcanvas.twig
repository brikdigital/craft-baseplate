{% set xdata = xdata is defined ? xdata : 'offcanvas' %}
{% set position = position is defined ? position : 'right' %}

{% set positionTransition = position == 'left' ? '-translate-x-full' : 'translate-x-full' %}
{% set positionCssClass = position == 'left' ? 'left-0' : 'right-0' %}

{% set width = width|default('w-full md:w-[440px] ') %}

<aside x-data="{{ xdata }}" tabindex="0">
    <div
        x-show="isOpen" x-cloak
        style="will-change:transform;"
        x-transition:enter="transform transition ease-in-out duration-300"
        x-transition:enter-start="{{ positionTransition }}"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transform transition ease-in-out duration-300"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="{{ positionTransition }}"
        class="fixed top-0 {{ positionCssClass }} {{ width }} flex flex-col min-h-svh h-full overflow-hidden overflow-x-hidden z-[1200] bg-purple-dark"
    >
        {% block content %}
        {% endblock %}
    </div>
    <div
        x-transition.opacity
        x-show="isOpen"
        x-cloak
        class="duration-300 fixed top-0 {{ positionCssClass }} h-screen w-screen overflow-hidden z-[1199] bg-black/60"
        x-data
        @click="close()"
    ></div>
</aside>