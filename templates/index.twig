{% extends '_layouts/default.twig' %}

{% block html %}
    {% set events = craft.entries().section('events').isFuture('eventDate', 'event', true).all() %}
    {% for event in events %}
        {{ event.title }} <br />
    {% endfor %}

    {% include '_components/blocks.twig' with {
		blocks: entry.blocks ? entry.blocks.eagerly().all() : [],
	} %}

{% endblock %}